# =============================================================================
#  TimeTracker — .gitignore
# =============================================================================

# ── Secrets (NEVER commit) ────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
!.env.example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
MANIFEST
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Database files ────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Backups ───────────────────────────────────────────────────────────────────
backups/
*.sql.gz
*.dump

# ── Docker ───────────────────────────────────────────────────────────────────
docker/nginx/ssl/          # SSL certificates — store separately
# docker volumes are not files, but named mounts appear here on some systems

# ── Temporary files ───────────────────────────────────────────────────────────
tmp/
temp/
_trash/
*.bak
*.tmp

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
