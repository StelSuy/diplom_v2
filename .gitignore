# =============================================================================
#  TimeTracker — .gitignore
# =============================================================================

# ── Secrets ──────────────────────────────────────────────────────────────────
# .env НЕ повинен потрапляти в git — він містить реальні паролі.
# Для налаштування: cp .env.example .env && змініть значення.
.env
.env.local
.env.production
.env.staging
!.env.example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
MANIFEST
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Database files (лише для локальної розробки) ──────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Backups ───────────────────────────────────────────────────────────────────
backups/
*.sql.gz
*.dump

# ── Alembic (автогенеровані файли не потрібні в git якщо є в __pycache__) ────
# alembic/versions/ — НЕ ігноруємо, міграції мають бути в git!

# ── Docker ───────────────────────────────────────────────────────────────────
docker/nginx/ssl/          # SSL-сертифікати — зберігати окремо, не в git
# Docker volumes — не файли, але на деяких системах з'являються

# ── Тимчасові / сміттєві файли ────────────────────────────────────────────────
_trash_*
fake_dump.sql
tmp/
temp/
_trash/
*.bak
*.tmp

# ── Статична адмінка (якщо генерується з фронтенд-проекту) ───────────────────
# app/static/ — НЕ ігноруємо, якщо index.html зберігається вручну.
# Якщо фронтенд збирається окремо (npm build → copy):
# app/static/assets/
# app/static/*.js
# app/static/*.css

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
