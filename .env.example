# =============================================================================
#  TimeTracker API — Environment Configuration
#
#  QUICK START:
#    cp .env.example .env
#    # Edit values marked with  ← CHANGE THIS
#    docker compose up -d
#
#  Generate secrets:
#    openssl rand -hex 64          # for JWT_SECRET
#    openssl rand -hex 32          # for DB passwords
# =============================================================================


# ── MySQL Database ────────────────────────────────────────────────────────────

# Root password (only used by MySQL internally)
DB_ROOT_PASSWORD=change_me_root               # ← CHANGE THIS

# Application database credentials
DB_NAME=timetracker_db
DB_USER=timetracker_user
DB_PASSWORD=change_me_db_password             # ← CHANGE THIS

# Connection (Docker: use service name "db"; bare-metal: use "localhost")
DB_HOST=db
DB_PORT=3306

# Full URL — constructed from above; change only if using external DB
DATABASE_URL=mysql+pymysql://timetracker_user:change_me_db_password@db:3306/timetracker_db?charset=utf8mb4


# ── Application ───────────────────────────────────────────────────────────────

# Environment: development | production
APP_ENV=production

# App version (shown in /health)
APP_VERSION=1.0.0


# ── Security ─────────────────────────────────────────────────────────────────

# JWT secret — MUST be at least 32 chars; generate: openssl rand -hex 64
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars  # ← CHANGE THIS

# JWT token TTL in minutes (default 60 = 1 hour)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Allowed CORS origins (comma-separated)
# Production: set to your real domain(s)
ALLOWED_ORIGINS=https://yourdomain.com

# Terminal scan cooldown (seconds between two scans from same terminal)
TERMINAL_SCAN_COOLDOWN_SECONDS=5


# ── Admin Account ─────────────────────────────────────────────────────────────
# Created automatically on first startup in the `users` table.
# Change ADMIN_PASSWORD before first run!

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production        # ← CHANGE THIS


# ── Gunicorn (production server) ──────────────────────────────────────────────

# Number of workers (recommended: 2 * CPU_cores + 1)
GUNICORN_WORKERS=4

# Request timeout in seconds
GUNICORN_TIMEOUT=120


# ── Logging ───────────────────────────────────────────────────────────────────

# Log level: debug | info | warning | error | critical
LOG_LEVEL=info

# SQLAlchemy query logging (true only for debugging, never in production)
SQL_ECHO=false
