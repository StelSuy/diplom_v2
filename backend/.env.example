# ============================================
# TimeTracker API — Environment Configuration
# ============================================
# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env

# --------------------------------------------
# MySQL — настройки базы данных
# --------------------------------------------

# Пароль root-пользователя MySQL (только для Docker)
MYSQL_ROOT_PASSWORD=64E4ecc6

# Имя базы данных
DB_NAME=timetracker_db

# Пользователь приложения (НЕ root)
DB_USER=timetracker_user

# Пароль пользователя приложения
DB_PASSWORD=64e4ecc6

# Хост БД — внутри Docker используй имя сервиса "db"
# На локальной машине без Docker: localhost
DB_HOST=db

# Порт MySQL
DB_PORT=3306

# --------------------------------------------
# DATABASE_URL — строка подключения SQLAlchemy
# Собирается автоматически из переменных выше.
# Если хочешь — можно задать вручную.
# --------------------------------------------
DATABASE_URL=mysql+pymysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?charset=utf8mb4

# --------------------------------------------
# FastAPI / приложение
# --------------------------------------------

# Режим: development | production
APP_ENV=development

# Секретный ключ для JWT токенов — смени на случайную строку!
# Сгенерировать: openssl rand -hex 32
SECRET_KEY=4f9a2b7e1c8d5f306a4b9c2d1e7f8a50b3c6d9e2f1a4b7c0d3e6f9a2b5c8d1e4

# Время жизни access токена (в минутах)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Разрешённые origins для CORS (через запятую)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --------------------------------------------
# Отладка
# --------------------------------------------

# Включить подробные SQL-запросы в логах (true/false)
SQL_ECHO=false
