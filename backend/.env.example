# =============================================================================
#  TimeTracker API — .env.example
#  Скопіюй: copy .env.example .env  (Windows)  /  cp .env.example .env (Linux)
# =============================================================================

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me
DB_NAME=timetracker_db
DB_USER=timetracker_user
DB_PASSWORD=change_me
# Локальний запуск → localhost  |  Docker Compose → db
DB_HOST=localhost
DB_PORT=3306
# Явна строка — без підстановок
DATABASE_URL=mysql+pymysql://timetracker_user:change_me@localhost:3306/timetracker_db?charset=utf8mb4

# ── FastAPI ───────────────────────────────────────────────────────────────────
APP_ENV=development
# Згенеруй: openssl rand -hex 64
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Admin — створюється в таблиці users автоматично при першому старті ────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production

# ── Debug ─────────────────────────────────────────────────────────────────────
SQL_ECHO=false
