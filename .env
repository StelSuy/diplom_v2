# =============================================================================
#  TimeTracker API — Environment Configuration
#
#  QUICK START (Docker):
#    cp .env.example .env
#    nano .env          # змініть значення позначені ← CHANGE THIS
#    docker compose up -d
#
#  QUICK START (без Docker, SQLite):
#    cp .env.example .env
#    nano .env          # встановіть DATABASE_URL=sqlite:///./timetracker.db
#    pip install -r requirements.txt
#    alembic upgrade head
#    uvicorn app.main:app --host 0.0.0.0 --port 8000
#
#  Генерація секретів:
#    openssl rand -hex 64    # для JWT_SECRET
#    openssl rand -hex 32    # для паролів БД
# =============================================================================


# ── База даних ────────────────────────────────────────────────────────────────

# --- Варіант A: MySQL через Docker (продакшн) ---
# docker-compose.yml сам будує DATABASE_URL з цих змінних:
DB_ROOT_PASSWORD=64E4ecc6               # ← CHANGE THIS
DB_NAME=timetracker_db
DB_USER=timetracker_user
DB_PASSWORD=64e4ecc6         # ← CHANGE THIS

# Хост: "db" — ім'я сервісу в Docker; "localhost" — якщо MySQL запущено окремо
DB_HOST=db
DB_PORT=3306

# --- Варіант B: SQLite (локально / тестування без Docker) ---
# Розкоментуйте наступний рядок і закоментуйте DB_* змінні вище:
# DATABASE_URL=sqlite:///./timetracker.db
DATABASE_URL=mysql+pymysql://timetracker_user:64e4ecc6@localhost:3306/timetracker_db?charset=utf8mb4

# ── Застосунок ────────────────────────────────────────────────────────────────

# Середовище: development | production
APP_ENV=production

# Версія (відображається у /health)
APP_VERSION=1.0.0


# ── Безпека ───────────────────────────────────────────────────────────────────

# JWT-секрет — мінімум 32 символи; згенеруйте: openssl rand -hex 64
JWT_SECRET=9f2d4c8a1b3e7f0a5d6c8b9e7a1f2c3d4e5f60718293a4b5c6d7e8f90123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Час життя токену в хвилинах
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Дозволені CORS-джерела (через кому)
# Для локальної мережі: ALLOWED_ORIGINS=*
# Для продакшну: ALLOWED_ORIGINS=https://yourdomain.com
ALLOWED_ORIGINS=*

# Кулдаун між двома сканами з одного терміналу (секунди)
TERMINAL_SCAN_COOLDOWN_SECONDS=60


# ── Адмін-акаунт ──────────────────────────────────────────────────────────────
# Створюється автоматично при першому запуску.
# ОБОВ'ЯЗКОВО змініть пароль перед першим запуском!

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123       # ← CHANGE THIS


# ── Gunicorn (продакшн-сервер) ────────────────────────────────────────────────

# Кількість воркерів (рекомендовано: 2 * кількість_CPU + 1)
GUNICORN_WORKERS=1

# Таймаут запиту в секундах
GUNICORN_TIMEOUT=120


# ── Логування ─────────────────────────────────────────────────────────────────

# Рівень: debug | info | warning | error | critical
LOG_LEVEL=info

# Логування SQL-запитів (тільки для налагодження, ніколи в продакшні)
SQL_ECHO=false
